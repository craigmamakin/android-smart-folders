<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Polished Outer Rim -->
    <item>
        <shape android:shape="oval">
            <stroke
                android:width="1.5dp"
                android:color="#B3FFFFFF" />
        </shape>
    </item>

    <!-- Top Surface Shine -->
    <item
        android:bottom="34dp"
        android:left="6dp"
        android:right="6dp"
        android:top="3dp">
        <shape android:shape="oval">
            <solid android:color="#66FFFFFF" />
        </shape>
    </item>
</layer-list>
